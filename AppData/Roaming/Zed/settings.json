// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
    "agent_buffer_font_size": 14.0,
    "agent_ui_font_size": 15.0,
    "diff_view_style": "split",
    "prettier": {
        "parser": "",
        "allowed": false
    },
    "use_system_prompts": true,
    "edit_predictions": {
        "open_ai_compatible_api": {
            "api_url": ""
        }
    },
    "cli_default_open_behavior": "existing_window",
    "auto_install_extensions": {
        "html": true
    },
    "language_models": {
        "openai_compatible": {
            },
    },
    "project_panel": {
        "dock": "right",
    },
    "outline_panel": {
        "dock": "right",
    },
    "collaboration_panel": {
        "dock": "right",
    },
    "agent": {
        "default_model": {
            "provider": "Kimi",
            "model": "Kimi-k2.6",
            "enable_thinking": false
        },
        "dock": "left",
        "favorite_models": [],
        "model_parameters": [],
    },
    "git_panel": {
        "dock": "right",
    },
    "agent_servers": {
        "claude-acp": {
            "default_config_options": {
                "mode": "auto"
            },
            "type": "registry"
        },
        "deepagents": {
            "type": "registry"
        },
        "Kimi Code CLI": {
            "default_config_options": {
                "mode": "auto"
            },
            "type": "custom",
            "command": "kimi",
            "args": [
                "acp"
            ],
            "env": {},
        },
        "codex-acp": {
            "type": "registry",
        },
    },
    "session": {
        "trust_all_worktrees": true,
    },
    "terminal": {
        "shell": "system",
        "font_size": 14.0,
        "font_family": "Consolas",
        "font_fallbacks": [
            "Monaco",
            "Source Code Pro",
            "monospace",
            "Courier New",
        ],
    },
    "multi_cursor_modifier": "cmd_or_ctrl",
    "minimap": {
        "show": "auto",
    },
    "buffer_font_family": "Consolas",
    "file_types": {
        "javascript": [
            "*.wxs"
        ],
        "html": [
            "*.rml"
        ],
        "jsonc": [
            "*.cjson"
        ],
        "css": [
            "*.wxss",
            "*.rcss"
        ],
    },
    "auto_indent_on_paste": false,
    "linked_edits": true,
    "semantic_tokens": "combined",
    "line_ending": "prefer_lf",
    "wrap_guides": [],
    "tab_size": 4,
    "base_keymap": "VSCode",
    "icon_theme": {
        "mode": "system",
        "light": "Zed (Default)",
        "dark": "Zed (Default)"
    },
    "ui_font_size": 15.0,
    "buffer_font_size": 13.0,
    "theme": {
        "mode": "dark",
        "light": "Ayu Dark",
        "dark": "Ayu Dark"
    },
}
